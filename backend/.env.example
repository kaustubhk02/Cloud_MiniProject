# Server
NODE_ENV=production
PORT=5000

# MySQL (e.g. Amazon RDS)
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=reimbursementDB

JWT_SECRET=use_a_long_random_string_at_least_32_chars

# Browser origin(s) for CORS — your EC2 public DNS, ALB, or CloudFront URL for the frontend
CLIENT_URL=https://your-frontend-domain.example.com

# Public origin of THIS API (no trailing slash) — used when building receipt links for disk uploads
# when the SPA is on another domain. Optional in dev (relative /uploads + Vite proxy works).
# API_PUBLIC_ORIGIN=https://ec2-xx-xx.compute.amazonaws.com:5000

# ── Receipt uploads to Amazon S3 (recommended on EC2) ─────────────────────
# Required for S3: bucket name and region. On EC2, attach an IAM role with at least:
#   s3:PutObject, s3:GetObject, s3:DeleteObject on arn:aws:s3:::YOUR_BUCKET_NAME/receipts/*
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY on EC2 if you use the instance role.
# Private objects: GET /api/reimbursements/:id/receipt returns a short-lived presigned URL.
S3_BUCKET_NAME=your-reimbursement-receipts-bucket
AWS_REGION=ap-south-1

# Optional: only if you are not using an IAM role (e.g. local testing against real S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional object ACL — many buckets block ACLs; leave unset for private objects (presigned GET).
# S3_OBJECT_ACL=public-read

# Local development: force disk storage in ./uploads even when S3 vars exist
# USE_LOCAL_UPLOADS=true
